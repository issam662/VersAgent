<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Restart: Tasks Editing and Subtasks Assignment 4 -->
    <system.webServer>
        <handlers>
            <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
        </handlers>
        <httpPlatform processPath="node.exe"
                      arguments=".\dist\index.js"
                      stdoutLogEnabled="true"
                      stdoutLogFile=".\logs\node.log"
                      startupTimeLimit="60"
                      processesPerApplication="1">
            <environmentVariables>
                <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
                <environmentVariable name="NODE_ENV" value="production" />
                <environmentVariable name="SHARE_USER" value="aptiv.com\ahhpks" />
                <environmentVariable name="SHARE_PASS" value="Delphi20232045--" />
            </environmentVariables>
        </httpPlatform>
        <rewrite>
            <rules>
                <!-- Redirect all traffic to HTTPS if needed, or handle client-side routing -->
                <!-- The Express app already handles routing, so we just pass everything to the handler -->
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
 
 
